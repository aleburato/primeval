{
  "name": "@aleburato/primeval",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "description": "TypeScript-first Node package for primeval image approximation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domoarigatomrburato/primeval.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "primeval": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "binding.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "generate:binding": "node scripts/generate-binding.mjs",
    "prepare:package": "npm run build && npm run generate:binding",
    "build:node": "napi build -p primeval-node --release --platform --no-js --dts binding.d.ts --output-dir . && npm run generate:binding",
    "check:napi-targets": "node scripts/napi-targets.mjs check-package",
    "bump:version": "node scripts/napi-targets.mjs bump-version",
    "verify:rust": "cargo fmt --check && cargo clippy --all-targets -- -D warnings && cargo test",
    "verify:node": "npm run check:napi-targets && npm run typecheck && npm run build && npm run build:node && npm test && npm run test:tooling",
    "verify:pack": "npm run prepare:package && npm pack --dry-run --ignore-scripts",
    "verify": "npm run verify:rust && npm run verify:node && npm run verify:pack",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/index.test.js test/contracts.test.js test/native.test.js test/cli.test.js",
    "test:tooling": "node --test test/tooling/*.test.js",
    "prepack": "npm run prepare:package"
  },
  "optionalDependencies": {
    "@aleburato/primeval-darwin-arm64": "0.1.1",
    "@aleburato/primeval-darwin-x64": "0.1.1",
    "@aleburato/primeval-linux-arm64-gnu": "0.1.1",
    "@aleburato/primeval-linux-x64-gnu": "0.1.1",
    "@aleburato/primeval-win32-x64-msvc": "0.1.1"
  },
  "napi": {
    "binaryName": "primeval-node",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.4"
  }
}
